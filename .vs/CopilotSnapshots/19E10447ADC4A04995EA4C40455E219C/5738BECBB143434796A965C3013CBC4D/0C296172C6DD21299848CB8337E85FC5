using MediatR;
using NexoCommerceAI.API.Common;
using NexoCommerceAI.Application.Products.GetProductById;

namespace NexoCommerceAI.API.Endpoints.Products;

internal sealed class GetProductByIdEndpoint : NexoCommerceAI.API.Endpoints.IEndpoint
{
    public void MapEndpoint(IEndpointRouteBuilder app)
    {
        app.MapGet("/api/products/{id:guid}", async (Guid id, ISender sender, CancellationToken cancellationToken) =>
        {
            var result = await sender.Send(new GetProductByIdQuery(id), cancellationToken);
            return result.ToOk();
        })
        .WithTags(Tags.Products);
    }
}
